# Plaid API credentials — get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here

# "sandbox" for testing with fake data, "development" for real banks (100 free accounts)
PLAID_ENV=sandbox

# Server port
PORT=8484

# Twilio SMS Alerts (optional — get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_PHONE_NUMBER=+1xxxxxxxxxx
