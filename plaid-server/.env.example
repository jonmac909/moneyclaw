# Plaid API credentials — get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here

# "sandbox" for testing with fake data, "development" for real banks (100 free accounts)
PLAID_ENV=sandbox

# Server port
PORT=8484

# Optional comma-separated extra browser origins. localhost:5173 and 127.0.0.1:5173
# are allowed automatically.
MONEYCLAW_ALLOWED_ORIGINS=

# Optional fixed API token. If omitted, the server creates a random token at startup
# and hands it only to allowed browser origins via /api/session.
MONEYCLAW_API_TOKEN=

# Optional 32-byte encryption key for local data files, encoded as hex or base64.
# If omitted, the server creates plaid-server/.moneyclaw-key locally.
MONEYCLAW_DATA_KEY=

# AI categorization sends transaction details to the local Claude CLI.
# Keep disabled unless you explicitly opt in.
MONEYCLAW_AI_CATEGORIZE_ENABLED=0

# Twilio SMS Alerts (optional — get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_PHONE_NUMBER=+1xxxxxxxxxx
